---
import type { TranslationData } from '@/i18n';
interface Props { t: TranslationData; }
const { t } = Astro.props;
---

<section class="py-20 bg-white text-navy-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {t.intro.items.map((item) => (
        <div class="group text-center p-6 rounded-xl border border-gray-200 hover:border-brand hover:shadow-lg transition-all duration-300">
          <div class="mb-4 overflow-hidden rounded-lg">
            <img src={`/images/boxes/${item.image}`} alt={item.title} class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand text-white mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5l-7 7 7 7" transform="rotate(270 12 12)" />
            </svg>
          </div>
          <p class="text-xs uppercase tracking-wider text-brand font-semibold mb-1">{item.subtitle}</p>
          <h3 class="text-lg font-bold mb-2">{item.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
