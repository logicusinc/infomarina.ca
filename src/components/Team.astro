---
import type { TranslationData } from '@/i18n';
interface Props { t: TranslationData; }
const { t } = Astro.props;
---

<section id="team" class="py-20 bg-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-white mb-4">{t.team.heading}</h2>
    <p class="text-center text-gray-300 max-w-2xl mx-auto mb-16">{t.team.description}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {t.team.members.map((member) => (
        <div class="bg-navy-dark rounded-xl border border-navy-light/30 overflow-hidden text-center hover:border-brand/50 transition-all duration-300 group">
          <div class="overflow-hidden">
            <img src={`/images/team/${member.image}`} alt={member.title} class="w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-5">
            <h3 class="font-bold text-brand text-lg mb-1">{member.title}</h3>
            <p class="text-gray-400 text-sm mb-4">{member.subtitle}</p>
            <a href={`mailto:${member.email}`} class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-brand/10 text-brand hover:bg-brand hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
