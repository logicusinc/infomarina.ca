---
import type { TranslationData } from '@/i18n';
interface Props { t: TranslationData; }
const { t } = Astro.props;

const screenshots = [
  { src: 'grille_petit.png', full: 'grille.png', category: 'reservations', title: 'Grille' },
  { src: 'statistique_petit.png', full: 'statistique.png', category: 'printing', title: 'Statistics' },
  { src: 'calendrier_petit.png', full: 'calendrier.png', category: 'reservations', title: 'Calendar' },
  { src: 'plan_petit.png', full: 'plan.png', category: 'layout', title: 'Interactive Layout' },
  { src: 'facturation_petit.png', full: 'facturation.png', category: 'billing', title: 'Billing' },
  { src: 'paiement_petit.png', full: 'paiement.png', category: 'billing', title: 'Payment' },
  { src: 'client_petit.png', full: 'client.png', category: 'billing', title: 'Client' },
  { src: 'plan_quai_petit.png', full: 'plan_quai.png', category: 'layout', title: 'Free Slip' },
  { src: 'plan_quai_client_petit.png', full: 'plan_quai_client.png', category: 'layout', title: 'Reserved Slip' },
  { src: 'statis.png', full: 'statis.png', category: 'printing', title: 'Reports' },
  { src: 'reservation_petit.png', full: 'reservation.png', category: 'reservations', title: 'Reservation' },
  { src: 'stat_petit.png', full: 'stat.png', category: 'printing', title: 'Stats' },
];

const filterKeys = Object.keys(t.portfolio.filters) as Array<keyof typeof t.portfolio.filters>;
---

<section id="screenshots" class="py-20 bg-white text-navy-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">{t.portfolio.heading}</h2>
    <p class="text-center text-gray-600 max-w-2xl mx-auto mb-10">{t.portfolio.description}</p>

    <!-- Filters -->
    <div class="flex flex-wrap justify-center gap-2 mb-10">
      {filterKeys.map((key) => (
        <button
          class:list={['filter-btn px-4 py-2 rounded-full text-sm font-medium transition-colors border', key === 'all' ? 'bg-brand text-white border-brand' : 'bg-white text-gray-600 border-gray-300 hover:border-brand hover:text-brand']}
          data-filter={key === 'all' ? '*' : key}
        >
          {t.portfolio.filters[key]}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div id="portfolio-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {screenshots.map((ss) => (
        <div class="portfolio-item rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition-all duration-300 group" data-category={ss.category}>
          <a href={`/images/portfolio/${ss.full}`} target="_blank" class="block relative overflow-hidden">
            <img src={`/images/portfolio/${ss.src}`} alt={ss.title} class="w-full group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            <div class="absolute inset-0 bg-brand/0 group-hover:bg-brand/20 transition-colors flex items-center justify-center">
              <svg class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
              </svg>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.portfolio-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => { b.classList.remove('bg-brand', 'text-white', 'border-brand'); b.classList.add('bg-white', 'text-gray-600', 'border-gray-300'); });
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-300');
      btn.classList.add('bg-brand', 'text-white', 'border-brand');

      const filter = (btn as HTMLElement).dataset.filter;
      items.forEach(item => {
        if (filter === '*' || (item as HTMLElement).dataset.category === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
