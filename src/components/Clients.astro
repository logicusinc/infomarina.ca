---
import type { TranslationData } from '@/i18n';
interface Props { t: TranslationData; }
const { t } = Astro.props;

const clientLogos = [
  { src: 'client-1-logo.png', alt: 'Client' },
  { src: 'client-2-logo.png', alt: 'Marina de la Chaudière' },
  { src: 'client-3-logo.jpg', alt: 'Client' },
  { src: 'client-5-logo.png', alt: 'Client' },
  { src: 'client-6-logo.png', alt: 'Client' },
  { src: 'client-7-logo.png', alt: 'Client' },
  { src: 'client-8-logo.png', alt: 'Client' },
];
---

<section id="clients" class="py-20 bg-white text-navy-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">{t.clients.heading}</h2>
    <p class="text-center text-gray-600 max-w-2xl mx-auto mb-16">{t.clients.description}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      {t.clients.items.map((client) => (
        <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden flex flex-col sm:flex-row">
          <div class="sm:w-1/3 flex-shrink-0">
            {'url' in client && client.url ? (
              <a href={client.url} target="_blank" rel="noopener">
                <img src={`/images/clients/${client.image}`} alt={client.name} class="w-full h-48 sm:h-full object-cover" loading="lazy" />
              </a>
            ) : (
              <img src={`/images/clients/${client.image}`} alt={client.name} class="w-full h-48 sm:h-full object-cover" loading="lazy" />
            )}
          </div>
          <div class="p-5 flex-1">
            <h3 class="font-bold text-navy-dark text-lg">{client.name}</h3>
            <p class="text-brand text-sm font-semibold mb-2">{client.location}</p>
            <p class="text-gray-600 text-sm leading-relaxed">{client.text}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Client logo bar -->
    <div class="flex flex-wrap items-center justify-center gap-8 pt-8 border-t border-gray-200">
      {clientLogos.map((logo) => (
        <img src={`/images/clients/${logo.src}`} alt={logo.alt} class="h-16 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0" loading="lazy" />
      ))}
    </div>
  </div>
</section>
